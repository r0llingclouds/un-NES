GLOBAL {
    STARTADDR $8000;
    INPUTOFFS 0;
    CPU "6502";
    COMMENTS 4;
};

# ---- Entry points ----
LABEL { NAME "Reset"; ADDR $8000; SIZE 1; };
LABEL { NAME "NMI_Handler"; ADDR $8082; SIZE 1; };
LABEL { NAME "IRQ_Handler"; ADDR $FFF0; SIZE 1; };

RANGE { START $8000; END $8081; TYPE Code; };
RANGE { START $8082; END $FFEF; TYPE Code; };
RANGE { START $FFF0; END $FFF9; TYPE Code; };

# Interrupt vector table
RANGE { START $FFFA; END $FFFF; TYPE WordTable; };
LABEL { NAME "VEC_NMI";   ADDR $FFFA; SIZE 2; };
LABEL { NAME "VEC_RESET"; ADDR $FFFC; SIZE 2; };
LABEL { NAME "VEC_IRQ";   ADDR $FFFE; SIZE 2; };

# ---- PPU Registers ----
LABEL { NAME "PPUCTRL";   ADDR $2000; SIZE 1; };
LABEL { NAME "PPUMASK";   ADDR $2001; SIZE 1; };
LABEL { NAME "PPUSTATUS"; ADDR $2002; SIZE 1; };
LABEL { NAME "OAMADDR";   ADDR $2003; SIZE 1; };
LABEL { NAME "OAMDATA";   ADDR $2004; SIZE 1; };
LABEL { NAME "PPUSCROLL"; ADDR $2005; SIZE 1; };
LABEL { NAME "PPUADDR";   ADDR $2006; SIZE 1; };
LABEL { NAME "PPUDATA";   ADDR $2007; SIZE 1; };

# ---- APU / I/O Registers ----
LABEL { NAME "SQ1_VOL";     ADDR $4000; SIZE 1; };
LABEL { NAME "SQ1_SWEEP";   ADDR $4001; SIZE 1; };
LABEL { NAME "SQ1_LO";      ADDR $4002; SIZE 1; };
LABEL { NAME "SQ1_HI";      ADDR $4003; SIZE 1; };
LABEL { NAME "SQ2_VOL";     ADDR $4004; SIZE 1; };
LABEL { NAME "SQ2_SWEEP";   ADDR $4005; SIZE 1; };
LABEL { NAME "SQ2_LO";      ADDR $4006; SIZE 1; };
LABEL { NAME "SQ2_HI";      ADDR $4007; SIZE 1; };
LABEL { NAME "TRI_LINEAR";  ADDR $4008; SIZE 1; };
LABEL { NAME "TRI_LO";      ADDR $400A; SIZE 1; };
LABEL { NAME "TRI_HI";      ADDR $400B; SIZE 1; };
LABEL { NAME "NOISE_VOL";   ADDR $400C; SIZE 1; };
LABEL { NAME "NOISE_LO";    ADDR $400E; SIZE 1; };
LABEL { NAME "NOISE_HI";    ADDR $400F; SIZE 1; };
LABEL { NAME "DMC_FREQ";    ADDR $4010; SIZE 1; };
LABEL { NAME "DMC_RAW";     ADDR $4011; SIZE 1; };
LABEL { NAME "DMC_START";   ADDR $4012; SIZE 1; };
LABEL { NAME "DMC_LEN";     ADDR $4013; SIZE 1; };
LABEL { NAME "OAMDMA";      ADDR $4014; SIZE 1; };
LABEL { NAME "SND_CHN";     ADDR $4015; SIZE 1; };
LABEL { NAME "JOY1";        ADDR $4016; SIZE 1; };
LABEL { NAME "JOY2";        ADDR $4017; SIZE 1; };
